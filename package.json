{
  "name": "files",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "files.mosni.dev - Hannah's File Drop",
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --config vite.ssr.config.ts",
    "test:unit": "docker compose -f docker-compose.verify.yml run --build --rm -T verify-unit",
    "verify": "node node_modules/typescript/bin/tsc --noEmit && docker compose -f docker-compose.verify.yml run --build --rm -T verify",
    "test:e2e": "docker compose -f docker-compose.verify.yml run --build --rm -T verify-e2e",
    "screenshot": "node scripts/screenshot.mjs"
  },
  "dependencies": {
    "fastify": "^5.0.0",
    "mysql2": "^3.0.0",
    "ioredis": "^5.0.0",
    "jose": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@fastify/static": "^10.0.0",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/helmet": "^13.0.0",
    "@tus/server": "^1.0.0",
    "@tus/file-store": "^1.0.0",
    "sharp": "^0.34.0",
    "tus-js-client": "^4.0.0",
    "react-router": "8.2.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "@types/node": "^24.0.0",
    "vite": "^8.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "vitest": "^4.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^29.0.0",
    "playwright": "^1.61.0",
    "@playwright/test": "^1.61.0"
  }
}
