# files.mosni.dev - environment contract. Copy to .env and fill in.
# NEVER commit a filled .env (gitignored). config.ts fails fast and loudly at boot if any of these is
# missing - a misconfigured deploy should crash, not limp along silently.

DB_HOST=mariadb
DB_PORT=3306
DB_USER=files
DB_PASS=
DB_NAME=files
REDIS_URL=redis://redis:6379

# bot-core's /say endpoint (D-43) - the silent write-action audit feed. Configurable, never a hardcoded
# `bot-core` host: the 2026-06-30 bot-framework amendment retires bot-core into a host-side runtime that
# still exposes /say, so this must keep pointing at whichever host owns the endpoint.
BOT_API=http://bot-core:8080

AUTH_ISSUER=https://auth.mosni.dev
APP_ORIGIN=https://files.mosni.dev
DL_ORIGIN=https://dl.mosni.dev

# Where uploaded bytes live on disk (D-13). Mounted from the box, not baked into the image.
STORAGE_ROOT=/data/storage

# The port Fastify listens on INSIDE the container (E1a: 3000). NOT the host-published port - that's
# hardcoded in docker-compose.yml's `ports:` mapping (see its box-time port note) and in nginx.conf's
# `proxy_pass`, following ../auth's precedent.
PORT=3000
